# Copy this file to .env.properties and replace the placeholder values.
# Spring Boot loads .env.properties automatically via spring.config.import.

# Free hosted PostgreSQL options:
# - Supabase: https://supabase.com/docs/guides/database
# - Railway: https://docs.railway.com/pricing/free-trial

DATABASE_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=replace-with-your-db-password
DATABASE_DRIVER=org.postgresql.Driver

# Optional app settings
FRONTEND_URL=http://localhost:5173
